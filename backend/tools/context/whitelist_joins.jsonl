{"_source_file": "whitelist_joins.json", "descripcion": "Whitelist de joins permitidos para consultas LLM. Prioriza joins exactos por clave. Los joins derivados o transformados deben usarse solo cuando la pregunta lo requiera explícitamente.", "version": "1.0", "joins_exactos": [{"dominio": "presupuestos", "left_table": "DDM_ERP.FAC_SGA_PRESUPUESTO_EXT", "right_table": "DDM_ERP.DIM_COMPANIA", "join_type_sugerido": "LEFT JOIN", "on": [{"left_column": "ID_COMPANIA", "operator": "=", "right_column": "ID_COMPANIA"}], "cardinalidad_esperada": "muchos_a_uno", "descripcion": "Enriquece presupuesto con código y nombre de compañía."}, {"dominio": "presupuestos", "left_table": "DDM_ERP.FAC_SGA_PRESUPUESTO_EXT", "right_table": "DDM_ERP.DIM_PLANTACION", "join_type_sugerido": "LEFT JOIN", "on": [{"left_column": "ID_PLANTACION", "operator": "=", "right_column": "ID_PLANTACION"}], "cardinalidad_esperada": "muchos_a_uno", "descripcion": "Enriquece presupuesto con datos de plantación."}, {"dominio": "presupuestos", "left_table": "DDM_ERP.FAC_SGA_PRESUPUESTO_EXT", "right_table": "DDM_ERP.DIM_SGA_ORIGEN", "join_type_sugerido": "LEFT JOIN", "on": [{"left_column": "ID_ORIGEN", "operator": "=", "right_column": "ID_ORIGEN"}], "cardinalidad_esperada": "muchos_a_uno", "descripcion": "Enriquece presupuesto con origen."}, {"dominio": "presupuestos", "left_table": "DDM_ERP.FAC_SGA_PRESUPUESTO_EXT", "right_table": "DDM_ERP.DIM_SGA_MATERIAL", "join_type_sugerido": "LEFT JOIN", "on": [{"left_column": "ID_MATERIAL", "operator": "=", "right_column": "ID_MATERIAL"}], "cardinalidad_esperada": "muchos_a_uno", "descripcion": "Enriquece presupuesto con material."}, {"dominio": "presupuestos", "left_table": "DDM_ERP.FAC_SGA_PRESUPUESTO_EXT", "right_table": "DDM_ERP.DIM_SGA_TIPO_DOCUMENTO", "join_type_sugerido": "LEFT JOIN", "on": [{"left_column": "ID_TIPO_DOCUMENTO", "operator": "=", "right_column": "ID_TIPO_DOCUMENTO"}], "cardinalidad_esperada": "muchos_a_uno", "descripcion": "Enriquece presupuesto con tipo de documento."}, {"dominio": "presupuestos", "left_table": "DDM_ERP.FAC_SGA_PRESUPUESTO_EXT", "right_table": "DDM_ERP.DIM_ESTADO", "join_type_sugerido": "LEFT JOIN", "on": [{"left_column": "ID_ESTADO_CULTIVO", "operator": "=", "right_column": "ID_ESTADO"}], "cardinalidad_esperada": "muchos_a_uno", "descripcion": "Enriquece presupuesto con estado del cultivo."}, {"dominio": "presupuestos", "left_table": "DDM_ERP.FAC_SGA_PRESUPUESTO_EXT", "right_table": "DDM_ERP.DIM_SGA_TIPO_CLASIFICACION", "join_type_sugerido": "LEFT JOIN", "on": [{"left_column": "ID_TIPO_CLASIFICACION", "operator": "=", "right_column": "ID_TIPO_CLASIFICACION"}], "cardinalidad_esperada": "muchos_a_uno", "descripcion": "Enriquece presupuesto con tipo de clasificación."}, {"dominio": "ventas", "left_table": "DDM_ERP.FAC_V_MQRY_KARDEX_AGRICOLA", "right_table": "DDM_ERP.DIM_PRODUCTO", "join_type_sugerido": "JOIN", "on": [{"left_column": "CODIGOCORTO", "operator": "=", "right_column": "ID_PRODUCTO"}], "cardinalidad_esperada": "muchos_a_uno", "descripcion": "Enriquece kardex agrícola con categoría contable y atributos de producto."}, {"dominio": "ventas", "left_table": "DDM_ERP.FAC_VENTA_TOTAL", "right_table": "DDM_ERP.DIM_PRODUCTO", "join_type_sugerido": "LEFT JOIN", "on": [{"left_column": "ID_PRODUCTO", "operator": "=", "right_column": "ID_PRODUCTO"}], "cardinalidad_esperada": "muchos_a_uno", "descripcion": "Enriquece ventas con jerarquía de producto."}, {"dominio": "ventas", "left_table": "DDM_ERP.FAC_VENTA_TOTAL", "right_table": "DDM_ERP.DIM_TIPO_DOCUMENTO", "join_type_sugerido": "LEFT JOIN", "on": [{"left_column": "ID_DOCUMENTO", "operator": "=", "right_column": "ID_DOCUMENTO"}], "cardinalidad_esperada": "muchos_a_uno", "descripcion": "Enriquece ventas con tipo y agrupación documental."}, {"dominio": "ventas", "left_table": "DDM_ERP.FAC_VENTA_TOTAL", "right_table": "DDM_ERP.DIM_CLIENTE", "join_type_sugerido": "LEFT JOIN", "on": [{"left_column": "ID_CLIENTE", "operator": "=", "right_column": "ID_CLIENTE"}], "cardinalidad_esperada": "muchos_a_uno", "descripcion": "Enriquece ventas con cliente, canal y ruta."}, {"dominio": "ventas", "left_table": "DDM_ERP.FAC_VENTA_TOTAL", "right_table": "DDM_ERP.DIM_FECHA", "join_type_sugerido": "LEFT JOIN", "on": [{"left_column": "DATE_CONTA", "operator": "=", "right_column": "FECHA"}], "cardinalidad_esperada": "muchos_a_uno", "descripcion": "Convierte la fecha contable a atributos calendario."}, {"dominio": "ventas", "left_table": "DDM_ERP.FAC_VENTA_TOTAL", "right_table": "DDM_ERP.DIM_UNIDAD_NEGOCIO", "join_type_sugerido": "LEFT JOIN", "on": [{"left_column": "ID_UNID_NEGOCIO", "operator": "=", "right_column": "ID_UNID_NEGOCIO"}], "cardinalidad_esperada": "muchos_a_uno", "descripcion": "Enriquece ventas con unidad de negocio."}, {"dominio": "ventas", "left_table": "DDM_ERP.FAC_VENTA_TOTAL", "right_table": "DDM_ERP.FAC_COSTO_MARGEN", "join_type_sugerido": "LEFT JOIN", "on": [{"left_column": "ID_PRODUCTO", "operator": "=", "right_column": "CODITEM"}, {"left_column": "MES_CONTABLE", "operator": "=", "right_column": "FECHA", "nota": "MES_CONTABLE se obtiene desde DIM_FECHA.MES tras unir DATE_CONTA = DIM_FECHA.FECHA"}], "cardinalidad_esperada": "muchos_a_muchos_controlado", "descripcion": "Join compuesto para costo por producto y mes. Debe usarse con deduplicación/agrupación de FAC_COSTO_MARGEN.", "requiere_preparacion": true}, {"dominio": "finanzas", "left_table": "DDM_ERP.FAC_ESTRESULTADOS_ACT_ALL", "right_table": "DDM_ERP.FAC_ESTRESULTADOS_PRESUP_ALL", "join_type_sugerido": "LEFT JOIN", "on": [{"left_column": "CCIA", "operator": "=", "right_column": "CCIA"}, {"left_column": "ANIO_FISCAL", "operator": "=", "right_column": "ANIO_FISCAL"}, {"left_column": "UNDNEGOCIO", "operator": "=", "right_column": "UNDNEGOCIO"}, {"left_column": "ID_CUENTA", "operator": "=", "right_column": "ID_CUENTA"}, {"left_column": "SUBLIBRO", "operator": "=", "right_column": "SUBLIBRO"}], "cardinalidad_esperada": "uno_a_uno_logico", "descripcion": "Permite contrastar real vs presupuesto por empresa, año fiscal, unidad de negocio, cuenta y sublibro."}], "joins_derivados": [{"dominio": "ventas", "left_table": "DDM_ERP.FAC_VENTA_TOTAL", "right_table": "DDM_ERP.DIM_FECHA", "join_type_sugerido": "LEFT JOIN", "expresion_join": "DDM_ERP.FAC_VENTA_TOTAL.DATE_CONTA = DDM_ERP.DIM_FECHA.FECHA", "descripcion": "Aunque es exacto por fecha, el LLM debe entender que la granularidad relevante suele ser mes (DIM_FECHA.MES)."}, {"dominio": "ventas", "left_table": "DDM_ERP.FAC_VENTA_TOTAL", "right_table": "DDM_ERP.FAC_COSTO_MARGEN", "join_type_sugerido": "LEFT JOIN", "expresion_join": "FVT.ID_PRODUCTO = CM.CODITEM AND DF.MES = CM.FECHA", "descripcion": "Requiere primero unir FAC_VENTA_TOTAL con DIM_FECHA para obtener el mes calendario usado en costo."}, {"dominio": "ventas", "left_table": "DDM_ERP.DIM_CLIENTE", "right_table": "rutas_agrupadas_logicas", "join_type_sugerido": "JOIN lógico", "expresion_join": "LEFT(DIM_CLIENTE.COD_RUTA, 2) = Ruta", "descripcion": "Usado en reglas y vistas comerciales; no es un join físico directo entre tablas de este set, sino una normalización de ruta."}, {"dominio": "finanzas", "left_table": "DDM_ERP.FAC_ESTRESULTADOS_ACT_ALL", "right_table": "calendario_mensual_logico", "join_type_sugerido": "UNPIVOT lógico", "expresion_join": "ENE_ACT..DIC_ACT -> FECHA mensual con día 01", "descripcion": "No es un join entre tablas sino una transformación permitida para llevar columnas mensuales a filas."}], "joins_no_permitidos_o_desaconsejados": [{"patron": "Cruzar tablas de presupuestos con ventas o finanzas sin una clave de negocio explícita", "motivo": "Las fuentes entregadas no muestran una relación directa y estable entre esos dominios."}, {"patron": "Unir FAC_V_MQRY_KARDEX_AGRICOLA con FAC_VENTA_TOTAL directamente por código de producto y fecha", "motivo": "Puede generar duplicidad y mezclar movimientos de inventario con ventas sin una regla de negocio explícita."}, {"patron": "Unir FAC_ESTRESULTADOS_ACT_ALL con DIM_COMPANIA por nombre", "motivo": "No se evidenció una clave robusta por nombre; usar códigos de compañía."}]}
